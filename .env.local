# Local development defaults — committed, zero-config.
#
# These values make `task start` and the e2e smoke tests work with no setup.
# They are deliberately weak and deliberately public: this file is the dev
# baseline, not a template. See .env.example for the documented reference of
# every variable and for what a production deployment must supply.
#
# DS_ENV is intentionally unset here, so the ProductionGuard in each service
# logs warnings about these defaults instead of refusing to start.
#
# Override per-machine in .env (gitignored).

COMPOSE_PROJECT_NAME=dataspaces

# ── Shared secrets (dev-only values) ──────────────────────────────────────────
EDC_API_KEY=insecure-dev-key
AUTH_SECRET=ds-local-dev-secret

# ── EDC ───────────────────────────────────────────────────────────────────────
EDC_PROVIDER_MANAGEMENT_URL=http://172.17.0.1:19193/management
EDC_PROVIDER_PROTOCOL_URL=http://172.17.0.1:19194/protocol/2025-1
EDC_CONSUMER_MANAGEMENT_URL=http://172.17.0.1:29193/management
EDC_CONSUMER_PROTOCOL_URL=http://172.17.0.1:29194/protocol/2025-1
EDC_RECEIVER_HTTP_ENDPOINT_PROVIDER=http://172.17.0.1:30001/webhooks/transfer-process
EDC_RECEIVER_HTTP_ENDPOINT_CONSUMER=http://172.17.0.1:31001/webhooks/transfer-process
EDC_PROVIDER_DB_URL=jdbc:postgresql://172.17.0.1:35432/edc_provider
EDC_CONSUMER_DB_URL=jdbc:postgresql://172.17.0.1:35432/edc_consumer

# ── Identity ──────────────────────────────────────────────────────────────────
CONNECTOR_PARTICIPANT_DID=did:web:provider.dataspaces.localhost
CONNECTOR_CONSUMER_PARTICIPANT_DID=did:web:consumer.dataspaces.localhost

# ── Service URLs ──────────────────────────────────────────────────────────────
CONNECTOR_IDENTITY_REGISTRY_URL=http://172.17.0.1:30005
CONNECTOR_DATASET_API_URL=http://172.17.0.1:30002
CONNECTOR_PROVENANCE_URL_PROVIDER=http://172.17.0.1:30000
CONNECTOR_PROVENANCE_URL_CONSUMER=http://172.17.0.1:31000
CONNECTOR_DATABASE_URL_PROVIDER=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/connector_provider
CONNECTOR_DATABASE_URL_CONSUMER=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/connector_consumer

# ── Identity Registry ─────────────────────────────────────────────────────────
IDENTITY_REGISTRY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/identity_registry

# ── Provenance ────────────────────────────────────────────────────────────────
PROVENANCE_DATABASE_URL_PROVIDER=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/provenance_provider
PROVENANCE_DATABASE_URL_CONSUMER=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/provenance_consumer

# ── Federated Catalog ─────────────────────────────────────────────────────────
CATALOG_CONNECTOR_URL=http://172.17.0.1:31001
CATALOG_IDENTITY_REGISTRY_URL=http://172.17.0.1:30005

# ── Dataset API ───────────────────────────────────────────────────────────────
DATASET_API_CONNECTOR_INTERNAL_URL=http://172.17.0.1:30001

# ── Keycloak / OIDC ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
AUTH_KEYCLOAK_ISSUER=http://keycloak.dataspaces.localhost:9010/realms/dataspaces
AUTH_KEYCLOAK_ID=ds-portal
AUTH_KEYCLOAK_SECRET=change-me-local-client-secret

# ── Portal ────────────────────────────────────────────────────────────────────
PORTAL_SERVICE_CLIENT_ID=svc-ds-portal
PORTAL_SERVICE_CLIENT_SECRET=svc-ds-portal
ORIGIN=http://portal.dataspaces.localhost:9010
CONNECTOR_URL=http://172.17.0.1:30001
FEDERATED_CATALOG_URL=http://172.17.0.1:30003

# ── Service tokens ────────────────────────────────────────────────────────────
SVC_DS_PORTAL_ID=svc-ds-portal
SVC_DS_PORTAL_SECRET=svc-ds-portal
# The e2e harness has its own client so the portal does not have to carry the
# permissions a test driver needs. Dev/CI realms only.
SVC_DS_E2E_ID=svc-ds-e2e
SVC_DS_E2E_SECRET=svc-ds-e2e
KEYCLOAK_TOKEN_URL=http://172.17.0.1:9080/realms/dataspaces/protocol/openid-connect/token
