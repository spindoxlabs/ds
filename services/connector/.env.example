# ds-connector — environment variable reference
# All variables have defaults in src/connector/config.py.
# Override by setting env vars directly or via docker-compose environment:.
# This file is documentation only — not loaded by the application.

# Database (default: postgres/postgres@host.docker.internal:35432/connector)
# CONNECTOR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:35432/connector

# EDC management endpoints
# EDC_PROVIDER_MANAGEMENT_URL=http://localhost:19193/management
# EDC_PROVIDER_PROTOCOL_URL=http://localhost:19194/protocol
# EDC_CONSUMER_MANAGEMENT_URL=http://localhost:29193/management
# EDC_CONSUMER_PROTOCOL_URL=http://localhost:29194/protocol
# EDC_API_KEY=insecure-dev-key

# Participant identity
# CONNECTOR_PARTICIPANT_ID=provider
# CONNECTOR_PARTICIPANT_BASE_URL=https://provider.dataspaces.localhost
# CONNECTOR_PARTICIPANT_DID=did:web:provider.dataspaces.localhost

# Dependent services
# CONNECTOR_DATASET_API_URL=http://localhost:30002
# CONNECTOR_PROVENANCE_URL=http://localhost:30000

# Governance
# CONNECTOR_PARTICIPANTS_REGISTRY_PATH=governance/participants.yaml
# CONNECTOR_GOVERNANCE_YAML_PATH=governance/governance.yaml

# Notifications (optional)
# CONNECTOR_NOTIFY_BACKENDS=smtp
# CONNECTOR_NOTIFY_SMTP_HOST=localhost
# CONNECTOR_NOTIFY_SMTP_PORT=1025
# CONNECTOR_NOTIFY_SMTP_FROM=consent@dataspaces.localhost
# CONNECTOR_NOTIFY_PORTAL_BASE_URL=https://portal.dataspaces.localhost

# CONNECTOR_DEBUG=false
