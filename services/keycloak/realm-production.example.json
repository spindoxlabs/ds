{
  "realm": "dataspaces",
  "enabled": true,
  "eventsEnabled": true,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "roles": {
    "realm": [
      {
        "name": "ds-admin",
        "description": "Dataspace platform administrator"
      },
      {
        "name": "dataset.admin",
        "description": "Dataset provider operator"
      }
    ],
    "client": {
      "ds-portal-production": [
        {
          "name": "admin",
          "description": "Portal administrator"
        },
        {
          "name": "dataset.admin",
          "description": "Portal dataset administration"
        }
      ]
    }
  },
  "groups": [
    {
      "name": "dataspace-admins",
      "realmRoles": [
        "ds-admin"
      ],
      "clientRoles": {
        "ds-portal-production": [
          "admin"
        ]
      }
    },
    {
      "name": "dataset-admins",
      "realmRoles": [
        "dataset.admin"
      ],
      "clientRoles": {
        "ds-portal-production": [
          "dataset.admin"
        ]
      }
    },
    {
      "name": "consumer-users"
    },
    {
      "name": "data-subjects"
    }
  ],
  "clientScopes": [
    {
      "name": "profile",
      "protocol": "openid-connect"
    },
    {
      "name": "email",
      "protocol": "openid-connect"
    },
    {
      "name": "roles",
      "protocol": "openid-connect"
    },
    {
      "name": "groups",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "organization",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "organization",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "organization",
            "claim.name": "organization",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "dataset.query",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "dataset.query",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "scope",
            "claim.value": "dataset.query",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "dataset.read",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "dataset.read",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "scope",
            "claim.value": "dataset.read",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "ds-portal-production",
      "name": "Dataspace Portal Production",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://portal.dataspaces.example.org/auth/callback/keycloak"
      ],
      "webOrigins": [
        "https://portal.dataspaces.example.org"
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "groups",
        "organization",
        "dataset.query",
        "dataset.read"
      ],
      "optionalClientScopes": []
    }
  ]
}
