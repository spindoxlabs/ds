# ── DID:web document hosting (HTTP for local dev) ────────────────────────────

http://provider.dataspaces.localhost {
	root * /did/provider.dataspaces.localhost
	rewrite /.well-known/did.json /did.json
	file_server
}

http://consumer.dataspaces.localhost {
	root * /did/consumer.dataspaces.localhost
	rewrite /.well-known/did.json /did.json
	file_server
}

http://trust-anchor.dataspaces.localhost {
	handle /credentials/* {
		root * /credentials
		uri strip_prefix /credentials
		file_server
	}
	root * /did/trust-anchor.dataspaces.localhost
	rewrite /.well-known/did.json /did.json
	file_server
}

http://users.dataspaces.localhost {
	root * /did/users.dataspaces.localhost
	file_server
}

