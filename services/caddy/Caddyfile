# ── DID:web document hosting ──────────────────────────────────────────────────
# Each participant DID resolves to https://<name>/.well-known/did.json.
# Static files served from caddy/did/<name>/did.json (mounted at /did in container).

http://provider.dataspaces.test, provider.dataspaces.test {
	root * /did/provider.dataspaces.test
	rewrite /.well-known/did.json /did.json
	file_server
}

http://consumer.dataspaces.test, consumer.dataspaces.test {
	root * /did/consumer.dataspaces.test
	rewrite /.well-known/did.json /did.json
	file_server
}

http://trust-anchor.dataspaces.test, trust-anchor.dataspaces.test {
	handle /credentials/* {
		root * /credentials
		uri strip_prefix /credentials
		file_server
	}
	root * /did/trust-anchor.dataspaces.test
	rewrite /.well-known/did.json /did.json
	file_server
}

http://users.dataspaces.test, users.dataspaces.test {
	root * /did/users.dataspaces.test
	file_server
}

