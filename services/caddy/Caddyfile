{
	local_certs
	auto_https off
}

# ── Producer Python services ─────────────────────────────────────────────────

connector.dataspaces.localhost, connector-producer.dataspaces.localhost {
	tls internal
	reverse_proxy host.docker.internal:30001
}

provenance.dataspaces.localhost, provenance-producer.dataspaces.localhost {
	tls internal
	reverse_proxy host.docker.internal:30000
}

dataset-api.dataspaces.localhost {
	tls internal
	reverse_proxy host.docker.internal:30002
}

federated-catalog.dataspaces.localhost {
	tls internal
	reverse_proxy host.docker.internal:30003
}

