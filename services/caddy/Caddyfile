# ── DID resolution (:80) — EDC did:web resolver fetches DID documents here ──
#
# did:web:provider.dataspaces.localhost → GET http://provider.dataspaces.localhost/.well-known/did.json
# Caddy rewrites to the identity-registry at /dids/did:web:{host}/did.json
# Resolved via Docker network aliases on the caddy service (no host port needed).
#
# NOTE: only works when EDC runs in Docker (same network as Caddy).
# If running EDC on the host (task edc-provider:run), add /etc/hosts entries
# and publish Caddy port 80, or use the DemoIdentityFallback.
#
http://*.dataspaces.localhost:80 {
	handle /.well-known/did.json {
		rewrite * /dids/did:web:{http.request.host}/did.json
		# Docker service name, on purpose: DID resolution stays on the Docker
		# network and host :80 is never exposed. In the pure-Docker topology the
		# EDCs resolve did:web:*.dataspaces.localhost via Caddy's network aliases
		# to here. When the identity-registry runs on the host (task dev), this
		# name does not resolve and the host-run EDC falls back to
		# DemoIdentityFallbackExtension — the documented dev tradeoff, guarded
		# out of production by task secrets:check.
		reverse_proxy identity-registry:30005
	}
	respond 404
}

# ── DID resolution (:9010) — enables host-side did:web resolution ───────────
#
# Specific hosts (portal, keycloak) take precedence over this wildcard.
# This catches participant/trust-anchor/user subdomains for DID document serving.
# Unlike :80, this port is published to the host so EDC on the host can resolve DIDs.
#
http://*.dataspaces.localhost:9010 {
	handle /.well-known/did.json {
		rewrite * /dids/did:web:{http.request.host}/did.json
		# Docker service name, on purpose: DID resolution stays on the Docker
		# network and host :80 is never exposed. In the pure-Docker topology the
		# EDCs resolve did:web:*.dataspaces.localhost via Caddy's network aliases
		# to here. When the identity-registry runs on the host (task dev), this
		# name does not resolve and the host-run EDC falls back to
		# DemoIdentityFallbackExtension — the documented dev tradeoff, guarded
		# out of production by task secrets:check.
		reverse_proxy identity-registry:30005
	}
	respond 404
}

# ── Keycloak ─────────────────────────────────────────────────────────────────

http://keycloak.dataspaces.localhost:9010 {
	reverse_proxy 172.17.0.1:9080
}

# ── Consumer gateway (:9000) ─────────────────────────────────────────────────

http://consumer.dataspaces.localhost:9000 {
	handle_path /api/connector/* {
		reverse_proxy 172.17.0.1:31001
	}

	handle_path /api/provenance/* {
		reverse_proxy 172.17.0.1:31000
	}
}

# ── Provider gateway (:9010) ─────────────────────────────────────────────────

http://portal.dataspaces.localhost:9010 {
	handle_path /api/connector/* {
		reverse_proxy 172.17.0.1:30001
	}

	handle_path /api/provenance/* {
		reverse_proxy 172.17.0.1:30000
	}

	handle_path /api/catalog/* {
		reverse_proxy 172.17.0.1:30003
	}

	handle_path /api/datasets/* {
		reverse_proxy 172.17.0.1:30002
	}

	# Portal (catch-all)
	reverse_proxy 172.17.0.1:30004
}
