# ds-provenance — environment variable reference
# All variables have defaults in src/provenance/config.py.
# Override by setting env vars directly or via docker-compose environment:.
# This file is documentation only — not loaded by the application.

# Database (default: postgres/postgres@172.17.0.1:35432/provenance)
# PROVENANCE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/provenance

# PROVENANCE_BASE_URL=https://provenance.dataspaces.localhost
# PROVENANCE_MAX_LINEAGE_DEPTH=20
# PROVENANCE_DEBUG=false
