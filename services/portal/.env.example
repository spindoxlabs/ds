# ds-portal — environment variables

# Session encryption (Auth.js). MUST be overridden in production.
AUTH_SECRET=change-me-in-production-min-32-chars

# User-facing OIDC login client
AUTH_KEYCLOAK_ID=ds-portal
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=https://keycloak.dataspaces.localhost/realms/dataspaces

# Service (client-credentials) client used only for the identity-registry
# email→DID lookup during login. Defaults fall back to the insecure dev value
# `svc-ds-portal`; the portal logs a warning when the default secret is used.
# Set a real secret in production.
PORTAL_SERVICE_CLIENT_ID=svc-ds-portal
PORTAL_SERVICE_CLIENT_SECRET=svc-ds-portal

# Backend service URLs
IDENTITY_REGISTRY_URL=http://localhost:30005
CONNECTOR_URL=http://localhost:30001
CONSUMER_CONNECTOR_URL=http://172.17.0.1:31001
CATALOGUE_URL=http://localhost:30002
FEDERATED_CATALOG_URL=http://localhost:30003
PROVENANCE_URL=http://localhost:30000
