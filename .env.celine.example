# Copy to .env.celine to point ds services at celine's Keycloak + dataset-api.
# Requires: celine stack running (Keycloak on :8080, dataset-api on :8001)
# Stop ds's keycloak + dataset-api-mock before using this.

# ── Portal auth — users authenticate against celine realm ─────────────────────
AUTH_KEYCLOAK_ISSUER=http://keycloak.celine.localhost/realms/celine
AUTH_KEYCLOAK_ID=ds-portal

# ── ds services — validate tokens from celine realm ──────────────────────────
CONNECTOR_OIDC_ISSUER_URL=http://172.17.0.1:8080/realms/celine
IDENTITY_REGISTRY_OIDC_ISSUER_URL=http://172.17.0.1:8080/realms/celine
PROVENANCE_OIDC_ISSUER_URL=http://172.17.0.1:8080/realms/celine
CATALOG_OIDC_ISSUER_URL=http://172.17.0.1:8080/realms/celine

# ── Service token acquisition — from celine realm ────────────────────────────
CONNECTOR_KEYCLOAK_TOKEN_URL=http://172.17.0.1:8080/realms/celine/protocol/openid-connect/token
CATALOG_KEYCLOAK_TOKEN_URL=http://172.17.0.1:8080/realms/celine/protocol/openid-connect/token
