# Consumer participant env. Copy to .env.consumer for local development.
# All defaults work out of the box with shared infra running.

# ── Shared secrets ─────────────────────────────────────────────────────────────
EDC_API_KEY=insecure-dev-key
STS_CONSUMER_SECRET=insecure-dev-secret

# ── Portal OIDC ────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-local-random-value
AUTH_KEYCLOAK_ID=ds-portal
AUTH_KEYCLOAK_SECRET=change-me-local-client-secret
AUTH_KEYCLOAK_ISSUER=http://keycloak.dataspaces.localhost:8080/realms/dataspaces
AUTH_KEYCLOAK_SCOPE=openid profile email

# ── DSP defaults (which provider to negotiate with) ───────────────────────────
# CONSUMER_DEFAULT_COUNTER_PARTY_ADDRESS=http://edc-provider:19194/protocol/2025-1
# CONSUMER_DEFAULT_ASSIGNER=did:web:provider.dataspaces.localhost
