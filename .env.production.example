# Production profile example. Do not put secret values here; point to secret files
# managed by Docker, your orchestrator, or an external secret manager.

COMPOSE_PROJECT_NAME=dataspaces-prod

# Docker secret source files. Create these files outside version control.
EDC_API_KEY_FILE=./data/secrets/production/edc_api_key
STS_PROVIDER_SECRET_FILE=./data/secrets/production/sts_provider_secret
STS_CONSUMER_SECRET_FILE=./data/secrets/production/sts_consumer_secret
AUTH_SECRET_FILE=./data/secrets/production/auth_secret
AUTH_KEYCLOAK_SECRET_FILE=./data/secrets/production/keycloak_client_secret
POSTGRES_PASSWORD_FILE=./data/secrets/production/postgres_password
EDC_PROVIDER_CONFIG_FILE=./data/secrets/production/edc-provider.properties
EDC_CONSUMER_CONFIG_FILE=./data/secrets/production/edc-consumer.properties
EDC_PROVIDER_VAULT_FILE=./data/secrets/production/edc-provider-vault.properties
EDC_CONSUMER_VAULT_FILE=./data/secrets/production/edc-consumer-vault.properties
PROVIDER_PRIVATE_KEY_FILE=./data/secrets/production/provider-key.json
CONSUMER_PRIVATE_KEY_FILE=./data/secrets/production/consumer-key.json
TRUST_ANCHOR_PRIVATE_KEY_FILE=./data/secrets/production/trust-anchor-key.json
CREDENTIALS_DIR=./data/credentials/production
CREDENTIAL_STATUS_LIST_FILE=./data/credentials/production/status-list.json
PRODUCTION_CADDYFILE=./services/caddy/Caddyfile.production.example
DID_DOCUMENTS_DIR=./data/did/production
GRAFANA_ADMIN_PASSWORD_FILE=./data/secrets/production/grafana_admin_password
PROMETHEUS_RETENTION=15d
PROMETHEUS_PORT=39090
GRAFANA_PORT=33000
BACKUP_DIR=./data/backups/postgres
BACKUP_RETENTION_DAYS=14
REPORT_DIR=./reports/operations
PROVENANCE_RETENTION_DAYS=365
ACCESS_LOG_RETENTION_DAYS=365

# Public production URLs. did:web and VC status registries must be reachable over HTTPS.
PUBLIC_BASE_DOMAIN=dataspaces.example.org
PROVIDER_DID_WEB=did:web:provider.dataspaces.example.org
CONSUMER_DID_WEB=did:web:consumer.dataspaces.example.org
TRUST_ANCHOR_DID_WEB=did:web:trust-anchor.dataspaces.example.org
USERS_DID_WEB_PREFIX=did:web:users.dataspaces.example.org
CONNECTOR_CREDENTIAL_STATUS_URL=https://trust-anchor.dataspaces.example.org/credentials/status-list.json
VC_WALLET_CREDENTIAL_STATUS_URL=https://trust-anchor.dataspaces.example.org/credentials/status-list.json
DATASPACE_ID=https://dataspaces.example.org

# OIDC/Keycloak. Use exact redirect URIs in the realm/client configuration.
AUTH_KEYCLOAK_ISSUER=https://keycloak.dataspaces.example.org/realms/dataspaces
AUTH_KEYCLOAK_ID=ds-portal-production
AUTH_KEYCLOAK_SCOPE=openid profile email roles dataset.query dataset.read groups organization
AUTH_KEYCLOAK_REDIRECT_URI=https://portal.dataspaces.example.org/auth/callback/keycloak
KEYCLOAK_REALM_EXPORT=./services/keycloak/realm-production.example.json

# Production-facing portal origin.
ORIGIN=https://portal.dataspaces.example.org
AUTH_URL=https://portal.dataspaces.example.org
NEXTAUTH_URL=https://portal.dataspaces.example.org

# Provider DSP address exposed by the production reverse proxy.
CONSUMER_DEFAULT_COUNTER_PARTY_ADDRESS=https://provider.dataspaces.example.org/protocol/2025-1
CONSUMER_DEFAULT_ASSIGNER=did:web:provider.dataspaces.example.org
