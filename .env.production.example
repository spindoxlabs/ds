# Production profile example. Do not put secret values here; use your
# orchestrator's secret management (Kubernetes Secrets, Vault, etc.).
# This file is the authoritative reference for helm chart values.

COMPOSE_PROJECT_NAME=dataspaces-prod

# ── Secrets (must be overridden — never use defaults in production) ────────────
EDC_API_KEY=CHANGE_ME
AUTH_SECRET=CHANGE_ME
AUTH_KEYCLOAK_SECRET=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

# ── Identity Registry ─────────────────────────────────────────────────────────
IDENTITY_REGISTRY_ENCRYPTION_KEY=CHANGE_ME
IDENTITY_REGISTRY_OIDC_ISSUER_URL=https://keycloak.dataspaces.example.org/realms/dataspaces
IDENTITY_REGISTRY_ADMIN_SCOPE=identity-registry.admin
IDENTITY_REGISTRY_TRUST_ANCHOR_DOMAIN=trust-anchor.dataspaces.example.org
IDENTITY_REGISTRY_DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@postgres:5432/identity_registry

# ── Public production URLs ─────────────────────────────────────────────────────
PUBLIC_BASE_DOMAIN=dataspaces.example.org
PROVIDER_DID_WEB=did:web:provider.dataspaces.example.org
CONSUMER_DID_WEB=did:web:consumer.dataspaces.example.org
TRUST_ANCHOR_DID_WEB=did:web:trust-anchor.dataspaces.example.org
USERS_DID_WEB_PREFIX=did:web:users.dataspaces.example.org
DATASPACE_ID=https://dataspaces.example.org

# ── OIDC/Keycloak ─────────────────────────────────────────────────────────────
AUTH_KEYCLOAK_ISSUER=https://keycloak.dataspaces.example.org/realms/dataspaces
AUTH_KEYCLOAK_ID=ds-portal-production
AUTH_KEYCLOAK_SCOPE=openid profile email roles dataset.query dataset.read groups organization
AUTH_KEYCLOAK_REDIRECT_URI=https://portal.dataspaces.example.org/auth/callback/keycloak

# ── Portal ─────────────────────────────────────────────────────────────────────
ORIGIN=https://portal.dataspaces.example.org
AUTH_URL=https://portal.dataspaces.example.org
NEXTAUTH_URL=https://portal.dataspaces.example.org

# ── DSP addresses ─────────────────────────────────────────────────────────────
CONSUMER_DEFAULT_COUNTER_PARTY_ADDRESS=https://provider.dataspaces.example.org/protocol/2025-1
CONSUMER_DEFAULT_ASSIGNER=did:web:provider.dataspaces.example.org

# ── Connector ──────────────────────────────────────────────────────────────────
CONNECTOR_IDENTITY_REGISTRY_URL=http://identity-registry:30005
# CONNECTOR_GOVERNANCE_OVERLAY_NAME=production

# ── Federated Catalog ──────────────────────────────────────────────────────────
CATALOG_IDENTITY_REGISTRY_URL=http://identity-registry:30005
CATALOG_BASE_URL=https://federated-catalog.dataspaces.example.org
