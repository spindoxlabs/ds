{
  "title": "Dataspace Runtime",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Services Up",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 4},
      "targets": [{"expr": "sum(ds_service_up)", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (service) (increase(ds_http_requests_total[5m]))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (service) (increase(ds_http_5xx_total[5m]))", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Credential Registry Up",
      "gridPos": {"x": 0, "y": 4, "w": 8, "h": 4},
      "targets": [{"expr": "up{job=\"credential-status-registry\"}", "refId": "A"}]
    }
  ]
}
