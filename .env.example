# Root shared environment — reference for cross-service secrets.
# Defaults are baked into each service's pydantic settings / docker-compose.
# This file is documentation only — not loaded by the application.

# EDC shared API key
# EDC_API_KEY=insecure-dev-key

# STS shared secrets (one per participant)
# STS_PROVIDER_SECRET=insecure-dev-secret
# STS_CONSUMER_SECRET=insecure-dev-secret

# Auth.js secret for portal
# AUTH_SECRET=change-me-in-production

# Keycloak
# AUTH_KEYCLOAK_SECRET=
