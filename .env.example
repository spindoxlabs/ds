# ==============================================================================
# Dataspace runtime environment — REFERENCE / PRODUCTION CONTRACT
# ==============================================================================
#
# This file documents *every* environment variable the platform reads, what it
# does, and what happens if it leaks. It is the model the Helm chart is built
# from: each entry below maps to a chart value or a Kubernetes Secret key.
#
# It is deliberately NOT a working configuration. Values marked CHANGE_ME must
# be supplied; the platform refuses to start with them when DS_ENV=production.
#
#   Local development  → use .env.local (committed, zero-config, works as-is).
#                        Nothing in this file is needed to run the stack on a
#                        laptop or to run the e2e smoke tests.
#   Production         → copy this file, fill every CHANGE_ME, set DS_ENV=production.
#
# Secret generation:
#   openssl rand -hex 32                                          # API keys, AUTH_SECRET
#   python -c 'import secrets;print(secrets.token_urlsafe(32))'   # Fernet passphrase
#
# ------------------------------------------------------------------------------
# HOW ENFORCEMENT WORKS
# ------------------------------------------------------------------------------
# Every Python service runs a ProductionGuard (libs/ds-auth/src/ds_auth/production.py)
# at startup. It collects all insecure/missing values and then:
#
#   DS_ENV unset or "dev"  → logs one warning per violation, starts normally.
#   DS_ENV=production      → logs ALL violations and REFUSES TO START.
#
# The guard reports every violation at once, so a chart author gets the complete
# list in a single deploy rather than discovering them one at a time.
# ==============================================================================

# Deployment environment. The Helm chart MUST set this to `production`.
# This is the single switch that turns dev-default warnings into hard failures.
DS_ENV=production

COMPOSE_PROJECT_NAME=dataspaces


# ==============================================================================
# CRITICAL SECRETS — every one of these is a full compromise if leaked
# ==============================================================================

# EDC Management API key — create/delete assets, policies and contracts,
# terminate transfers.
# Leak → full contract administration of this participant's connector.
# It is no longer the credential the EDC extensions or the dataset-api present
# to ds-connector's /internal/* API; both now use their own Keycloak client
# credentials (SVC_EDC_* / SVC_DS_DATASET_API_*), so this value spans one trust
# boundary rather than three. ds-connector still accepts it on /internal/* as a
# fallback for un-migrated deployments; that branch is slated for removal.
# Dev default: insecure-dev-key
EDC_API_KEY=CHANGE_ME
# Alternative: read the key from a mounted file instead of the environment.
# Prefer this in Kubernetes (mount a Secret as a file).
# EDC_API_KEY_FILE=/run/secrets/edc-api-key

# Fernet passphrase encrypting every participant DID private key at rest.
# Leak → decrypt all DID private keys → impersonate any participant.
# LOSS → every stored private key becomes unrecoverable. Back this up.
# Dev default: dev-encryption-key-change-in-production
IDENTITY_REGISTRY_ENCRYPTION_KEY=CHANGE_ME

# Auth.js session encryption key for the portal.
# Leak → forge portal sessions with arbitrary user identity and VC claims.
# Dev default: ds-local-dev-secret / dev-secret-change-in-prod
AUTH_SECRET=CHANGE_ME

# Keycloak admin account. Owns every identity in the dataspace.
# Dev default: admin / admin
KEYCLOAK_ADMIN_USERNAME=CHANGE_ME
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# PostgreSQL. In dev a single superuser backs all six databases; production
# should provision one least-privilege role per service instead.
# Dev default: postgres / postgres
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME


# ==============================================================================
# ZERO-TRUST ENFORCEMENT — these disable authentication when left at dev values
# ==============================================================================

# OIDC issuer per service. When unset, JWT signature/audience/issuer verification
# is DISABLED (see *_OIDC_INSECURE_DEV below). Setting the issuer enforces
# verification regardless of the insecure flag.
CONNECTOR_OIDC_ISSUER_URL=https://CHANGE_ME/realms/dataspaces
IDENTITY_REGISTRY_OIDC_ISSUER_URL=https://CHANGE_ME/realms/dataspaces
PROVENANCE_OIDC_ISSUER_URL=https://CHANGE_ME/realms/dataspaces
CATALOG_OIDC_ISSUER_URL=https://CHANGE_ME/realms/dataspaces

# Dev escape hatches. Each defaults to `true` in the service settings so the
# stack runs with no Keycloak. All four MUST be false in production.
CONNECTOR_OIDC_INSECURE_DEV=false
IDENTITY_REGISTRY_OIDC_INSECURE_DEV=false
PROVENANCE_OIDC_INSECURE_DEV=false
CATALOG_OIDC_INSECURE_DEV=false

# Trust-anchor public key used to verify user Verifiable Credentials on the
# consent and consumer APIs. When unset, the connector cannot authenticate the
# data subject presenting an X-User-VC header — leaving it unset in production
# disables the data-subject sovereignty control entirely.
CONNECTOR_TRUST_ANCHOR_KEY_PATH=/etc/ds/trust-anchor-public.json
CONNECTOR_TRUST_ANCHOR_DID=did:web:CHANGE_ME
# Must be false in production; permits unsigned VCs when no key path is set.
CONNECTOR_VC_INSECURE_DEV=false

# EDC demo identity fallback. When true, the EDC accepts self-issued DCP tokens
# WITHOUT signature verification whenever the real verifier rejects them —
# a complete authentication bypass. The extension defaults to false; dev compose
# sets it true explicitly. NEVER set this in production.
# DS_DEMO_IDENTITY_ENABLED=false


# ==============================================================================
# KEYCLOAK SERVICE CLIENTS
# ==============================================================================
# Defined in services/keycloak/clients.yaml. In dev each secret defaults to its
# own client_id (e.g. svc-ds-portal / svc-ds-portal) — guessable, and several of
# these clients hold admin-level scopes:
#
#   svc-ds-portal            connector.provider.*, identity-registry.read, ...
#   svc-ds-onboarding        identity-registry.admin
#   svc-ds-identity-registry identity-registry.admin
#
# No service client carries a `*.admin` scope on the connector: admin is an
# operator grant (a user's own token or an admin CLI), and it is a superset, so
# granting it to a process hands that process every permission of that service.

SVC_DS_IDENTITY_REGISTRY_SECRET=CHANGE_ME
SVC_DS_ONBOARDING_SECRET=CHANGE_ME
SVC_DS_PORTAL_SECRET=CHANGE_ME
SVC_DS_CONNECTOR_SECRET=CHANGE_ME
SVC_DS_FEDERATED_CATALOG_SECRET=CHANGE_ME
# The dataset-api PEP's identity on ds-connector /internal/* — consent checks
# and the row-filter subject list. Holds connector.internal.
SVC_DS_DATASET_API_SECRET=CHANGE_ME
# The EDC JVM's identity: /internal/* during ODRL policy evaluation, and
# /webhooks/contract-negotiation to report its own negotiation state. Holds
# connector.internal + connector.webhook + identity-registry.read. Replaces
# EDC_API_KEY on those calls, so a leak here does not also hand over EDC's
# Management API, and /internal/* callers become distinguishable in an audit.
SVC_EDC_SECRET=CHANGE_ME

# Identity-registry's own Keycloak admin client (realm/org provisioning).
# Dev default: insecure-dev-secret
KEYCLOAK_CLIENT_ID=ds-identity-registry
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_ADMIN_URL=https://CHANGE_ME


# ==============================================================================
# PORTAL OIDC (Auth.js)
# ==============================================================================
AUTH_KEYCLOAK_ISSUER=https://CHANGE_ME/realms/dataspaces
AUTH_KEYCLOAK_ID=ds-portal
AUTH_KEYCLOAK_SECRET=CHANGE_ME
AUTH_KEYCLOAK_SCOPE=openid profile email
# Public origin of the portal; must match the OIDC redirect URI in Keycloak.
ORIGIN=https://CHANGE_ME
# Portal service account used for server-side API calls.
PORTAL_SERVICE_CLIENT_ID=svc-ds-portal
PORTAL_SERVICE_CLIENT_SECRET=CHANGE_ME


# ==============================================================================
# PARTICIPANT IDENTITY
# ==============================================================================
# The DIDs this deployment acts as. In dev these are *.dataspaces.localhost;
# production must use real did:web domains resolvable over HTTPS.
CONNECTOR_PARTICIPANT_DID=did:web:CHANGE_ME
CONNECTOR_CONSUMER_PARTICIPANT_DID=did:web:CHANGE_ME
IDENTITY_REGISTRY_TRUST_ANCHOR_DOMAIN=CHANGE_ME

# Role of this connector instance: `provider` or `consumer`. Required, no default.
CONNECTOR_ROLE=provider


# ==============================================================================
# DATABASES
# ==============================================================================
# One database per service. Production should use a distinct least-privilege
# role per URL rather than the shared superuser used in dev.
IDENTITY_REGISTRY_DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/identity_registry
CONNECTOR_DATABASE_URL_PROVIDER=postgresql+asyncpg://USER:PASS@HOST:5432/connector_provider
CONNECTOR_DATABASE_URL_CONSUMER=postgresql+asyncpg://USER:PASS@HOST:5432/connector_consumer
PROVENANCE_DATABASE_URL_PROVIDER=postgresql+asyncpg://USER:PASS@HOST:5432/provenance_provider
PROVENANCE_DATABASE_URL_CONSUMER=postgresql+asyncpg://USER:PASS@HOST:5432/provenance_consumer
EDC_PROVIDER_DB_URL=jdbc:postgresql://HOST:5432/edc_provider
EDC_CONSUMER_DB_URL=jdbc:postgresql://HOST:5432/edc_consumer


# ==============================================================================
# EDC ENDPOINTS
# ==============================================================================
# Management APIs are privileged — never expose them publicly. In Kubernetes
# these should be ClusterIP-only.
EDC_PROVIDER_MANAGEMENT_URL=http://edc-provider:19193/management
EDC_PROVIDER_PROTOCOL_URL=https://CHANGE_ME/protocol/2025-1
EDC_CONSUMER_MANAGEMENT_URL=http://edc-consumer:29193/management
EDC_CONSUMER_PROTOCOL_URL=https://CHANGE_ME/protocol/2025-1
# The EDC reports its negotiation lifecycle to ds-connector from inside the
# extensions (NegotiationEventPublisher), addressed by ds.connector.internal.url
# in services/connector/config/*.properties. There is no callback-URL variable:
# EDC 0.16.0 has no `edc.receiver.http.*` setting, and the static-callback
# extension would need a fourth shared secret to authenticate.


# ==============================================================================
# INTERNAL SERVICE URLS
# ==============================================================================
CONNECTOR_IDENTITY_REGISTRY_URL=http://identity-registry:30005
CONNECTOR_DATASET_API_URL=http://dataset-api:30002
CONNECTOR_PROVENANCE_URL_PROVIDER=http://ds-provenance-provider:30000
CONNECTOR_PROVENANCE_URL_CONSUMER=http://ds-provenance-consumer:31000
CONNECTOR_URL=http://ds-connector-provider:30001
FEDERATED_CATALOG_URL=http://ds-federated-catalog:30003
CATALOG_CONNECTOR_URL=http://ds-connector-consumer:31001
CATALOG_IDENTITY_REGISTRY_URL=http://identity-registry:30005
DATASET_API_CONNECTOR_INTERNAL_URL=http://ds-connector-provider:30001

# Keycloak token endpoints for client-credentials service tokens.
CONNECTOR_KEYCLOAK_TOKEN_URL=https://CHANGE_ME/realms/dataspaces/protocol/openid-connect/token
CATALOG_KEYCLOAK_TOKEN_URL=https://CHANGE_ME/realms/dataspaces/protocol/openid-connect/token
DATASET_API_KEYCLOAK_TOKEN_URL=https://CHANGE_ME/realms/dataspaces/protocol/openid-connect/token
# Consumed by the EDC JVM (ds.connector.internal.token.url in *.properties).
DS_KEYCLOAK_TOKEN_URL=https://CHANGE_ME/realms/dataspaces/protocol/openid-connect/token
KEYCLOAK_TOKEN_URL=https://CHANGE_ME/realms/dataspaces/protocol/openid-connect/token

# Which client each of those two authenticates as. The secrets are the
# SVC_*_SECRET values above; these are only the client ids.
DATASET_API_SERVICE_CLIENT_ID=svc-ds-dataset-api
DS_CONNECTOR_CLIENT_ID=svc-edc


# ==============================================================================
# DSP DEFAULTS (consumer-side catalogue browsing)
# ==============================================================================
CONSUMER_DEFAULT_COUNTER_PARTY_ADDRESS=https://CHANGE_ME/protocol/2025-1
CONSUMER_DEFAULT_ASSIGNER=did:web:CHANGE_ME


# ==============================================================================
# OPTIONAL / TUNING — safe defaults, override only when needed
# ==============================================================================

# Governance overlay merged on top of governance.yaml (e.g. `prod`).
# CONNECTOR_GOVERNANCE_OVERLAY_NAME=
# CONNECTOR_ODRL_PROFILE_PATH=
# Credential revocation (StatusList2021).
# CONNECTOR_CREDENTIAL_STATUS_URL=
# CONNECTOR_CREDENTIAL_STATUS_PATH=
# Accept participants absent from the registry. Keep false.
# CONNECTOR_ALLOW_UNKNOWN_PARTICIPANTS=false
# Negotiation/transfer polling.
# CONNECTOR_NEGOTIATION_TIMEOUT=120
# CONNECTOR_TRANSFER_TIMEOUT=120
# CONNECTOR_NEGOTIATION_POLL_INTERVAL=2
# CONNECTOR_TRANSFER_POLL_INTERVAL=2
# Consent notification backends: null, smtp, webhook (comma-separated).
# CONNECTOR_NOTIFY_BACKENDS=null
# Registry cache TTL (seconds).
# CONNECTOR_OWNERS_REGISTRY_CACHE_TTL=300

# Credential lifetimes (days).
# IDENTITY_REGISTRY_DEFAULT_CREDENTIAL_TTL_DAYS=365
# IDENTITY_REGISTRY_MAX_CREDENTIAL_TTL_DAYS=730

# Federated catalog crawler.
# CATALOG_CRAWL_INTERVAL=300
# CATALOG_STARTUP_DELAY=10
# CATALOG_MAX_DATASETS_PER_PROVIDER=100

# Provenance lineage traversal cap.
# PROVENANCE_MAX_LINEAGE_DEPTH=20

# Dataset API mock. Point at a real dataset API to replace the built-in fixtures.
# DATASET_API_EXTERNAL_QUERY_URL=
# DATASET_API_ENFORCE_CONSENT=true

# Debug/reload. Never enable in production.
# CONNECTOR_DEBUG=false
# IDENTITY_REGISTRY_DEBUG=false
# PROVENANCE_DEBUG=false
# CATALOG_DEBUG=false
