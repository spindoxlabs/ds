# Dataspace runtime env.
# Copy to .env for local development. All defaults work out of the box.
# Do not commit real secrets.

COMPOSE_PROJECT_NAME=dataspaces

# ── Shared infrastructure ──────────────────────────────────────────────────────
EDC_API_KEY=insecure-dev-key
STS_PROVIDER_SECRET=insecure-dev-secret
STS_CONSUMER_SECRET=insecure-dev-secret
AUTH_SECRET=change-me-local-random-value

# ── Portal OIDC (Keycloak) ────────────────────────────────────────────────────
AUTH_KEYCLOAK_ISSUER=http://keycloak.dataspaces.localhost:8080/realms/dataspaces
AUTH_KEYCLOAK_ID=ds-portal
AUTH_KEYCLOAK_SECRET=change-me-local-client-secret
AUTH_KEYCLOAK_SCOPE=openid profile email

# ── Keycloak admin ─────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── DSP defaults ───────────────────────────────────────────────────────────────
CONSUMER_DEFAULT_COUNTER_PARTY_ADDRESS=http://edc-provider:19194/protocol/2025-1
CONSUMER_DEFAULT_ASSIGNER=did:web:provider.dataspaces.localhost

# ── Service database URLs (override per-service if needed) ─────────────────────
# CONNECTOR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/connector
# PROVENANCE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/provenance
# IDENTITY_REGISTRY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@172.17.0.1:35432/identity_registry

# ── Connector ──────────────────────────────────────────────────────────────────
# CONNECTOR_DATASET_API_URL=http://localhost:30002
# CONNECTOR_PROVENANCE_URL=http://localhost:30000
# EDC_PROVIDER_MANAGEMENT_URL=http://localhost:19193/management
# EDC_CONSUMER_MANAGEMENT_URL=http://localhost:29193/management

# ── Federated catalog ─────────────────────────────────────────────────────────
# CATALOG_CONNECTOR_URL=http://172.17.0.1:30001

# ── Dataset API mock ──────────────────────────────────────────────────────────
# DATASET_API_CONNECTOR_INTERNAL_URL=http://172.17.0.1:30001

# ── STS ────────────────────────────────────────────────────────────────────────
# STS_PRIVATE_KEY_PATH=data/keys/provider-key.json
# STS_PARTICIPANT_DID=did:web:provider.dataspaces.localhost

# ── VC Wallet ──────────────────────────────────────────────────────────────────
# VC_WALLET_CREDENTIALS_PATH=data/credentials/provider
# VC_WALLET_PARTICIPANT_DID=did:web:provider.dataspaces.localhost
